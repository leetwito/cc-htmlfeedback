  "repository": { "type": "git", "url": "git+https://github.com/leetwito/cc-htmlfeedback.git" },
  "bugs": { "url": "https://github.com/leetwito/cc-htmlfeedback/issues" },
  "author": "leetwito",
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "node build.js",
    "check": "node build.js --check",
    "test": "node --test --test-force-exit",
    "serve": "node server.js"
  },
